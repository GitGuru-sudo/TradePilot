# ========== BINANCE FUTURES TESTNET CONFIGURATION ==========
# Get API credentials from: https://testnet.binancefuture.com → Account → API Management
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_TESTNET=true

# Set to 'false' to make real API calls to testnet, or 'true' for mock responses (safe for testing)
USE_MOCK_BINANCE=true

# ========== FIREBASE CONFIGURATION (Optional) ==========
# Only needed if you want to use the web dashboard with authentication
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}
USE_MOCK_FIREBASE=true

# ========== SUPABASE CONFIGURATION (Optional) ==========
# Only needed if you want to persist order history
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========== APPLICATION SETTINGS ==========
PROJECT_NAME="Binance Futures Trading Bot"
SECRET_KEY=your-secret-key-for-local-dev
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
